---
import { NAV_LINKS } from "../config/navigation";
import { siteData } from "../data/site";

const links = NAV_LINKS;
---

<header class="navbar">
  <div class="container mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <!-- Logo + Site Name -->
    <a href="/" class="flex items-center gap-2">
      <img src="/images/Hon_Musasiizi.png" alt="Logo" class="w-8 h-8 sm:w-10 sm:h-10 rounded-full object-cover" />
      <span class="font-display text-sm sm:text-lg font-bold">Hon. Musasizi</span>
    </a>

    <nav class="hidden items-center md:flex" aria-label="Primary">
      <ul class="flex flex-wrap items-center justify-end gap-6 text-sm font-medium">
        {
          links.map(({ href, label, children }) => (
            <li class="relative group">
              {children ? (
                <>
                  <button
                    type="button"
                    class="flex items-center gap-1 transition-smooth hover:text-gold"
                  >
                    {label}
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="absolute right-0 top-full mt-2 hidden w-44 rounded-xl glass py-2 group-hover:block">
                    <ul class="flex flex-col">
                      {children.map(({ href, label }) => (
                        <li>
                          <a href={href} class="block px-4 py-2 transition-smooth hover:bg-white/5 hover:text-gold">
                            {label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </>
              ) : (
                <a href={href} class="transition-smooth hover:text-gold">
                  {label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Mobile Hamburger -->
    <button
      type="button"
      class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[#c8922a] md:hidden"
      id="nav-menu-btn"
      aria-controls="nav-mobile-panel"
      aria-expanded="false"
      aria-label="Open menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Mobile Full Screen Panel -->
    <div
      id="nav-mobile-panel"
      class="fixed inset-0 z-50 hidden bg-[#0a0a0e]/98 backdrop-blur-xl md:hidden overflow-y-auto"
      style="height: 100dvh;"
      role="dialog"
      aria-label="Mobile navigation"
    >
      <div class="flex flex-col h-full">
        <!-- Mobile Header -->
        <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
          <a href="/" class="flex items-center gap-2" onclick="closeMobileMenu()">
            <img src="/images/Hon_Musasiizi.png" alt="Logo" class="w-10 h-10 rounded-full object-cover" />
            <span class="font-display text-lg font-bold">Hon. Musasizi</span>
          </a>
          <button
            type="button"
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-white/10"
            id="nav-close-btn"
            aria-label="Close menu"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 6L6 18M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <!-- Mobile Nav Links -->
        <nav class="flex-1 overflow-y-auto px-4 py-2">
          <ul class="flex flex-col gap-0 text-sm font-medium">
            {
              links.map(({ href, label, children }) => (
                <li>
                  {children ? (
                    <>
                      <div class="border-b border-white/10 pb-2 mb-2">
                        <span class="text-sm text-tan/50">{label}</span>
                      </div>
                      <ul class="mt-2 flex flex-col gap-0 pl-2">
                        {children.map(({ href, label }) => (
                          <li>
                            <a href={href} class="block rounded-lg px-3 py-2 transition-smooth hover:bg-white/5 hover:text-gold" onclick="closeMobileMenu()">
                              {label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <a href={href} class="block rounded-lg px-3 py-2 transition-smooth hover:bg-white/5 hover:text-gold" onclick="closeMobileMenu()">
                      {label}
                    </a>
                  )}
                </li>
              ))
            }
          </ul>
        </nav>
        <!-- Mobile Footer -->
        <div class="border-t border-white/10 px-4 py-4 text-center text-xs text-tan/40">
          © {new Date().getFullYear()} {siteData.name}
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  function closeMobileMenu() {
    var panel = document.getElementById("nav-mobile-panel");
    if(panel) panel.classList.add("hidden");
    document.body.classList.remove("menu-open");
  }
  
  (function() {
    var btn = document.getElementById("nav-menu-btn");
    var closeBtn = document.getElementById("nav-close-btn");
    var panel = document.getElementById("nav-mobile-panel");
    if (!btn || !panel || !closeBtn) return;

    function setOpen(open) {
      panel.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", open ? "true" : "false");
      if (open) {
        document.body.classList.add("menu-open");
      } else {
        document.body.classList.remove("menu-open");
      }
    }

    btn.addEventListener("click", function () {
      setOpen(panel.classList.contains("hidden"));
    });

    closeBtn.addEventListener("click", function () {
      setOpen(false);
    });

    panel.querySelectorAll("a").forEach(function (a) {
      a.addEventListener("click", function () {
        setOpen(false);
      });
    });
  })();
</script>

<style is:global>
  body.menu-open {
    overflow: hidden;
    height: 100vh;
  }
</style>