---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-10 text-center">
  {eyebrow && <p class="section-label">{eyebrow}</p>}
  <h2 class="font-display text-3xl md:text-4xl font-bold">{title}</h2>
  {description && <p class="mt-3 mt-2 max-w-2xl mx-auto text-tan/60">{description}</p>}
</div>