---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = (async () => {
  const items = await getCollection("gallery");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}) satisfies GetStaticPaths;

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={`${item.data.title} | Gallery`}>
  <section class="container mx-auto max-w-4xl px-6 py-10 md:py-16">
    <article class="card overflow-hidden p-0 sm:p-2 md:p-4">
      <img
        src={item.data.image}
        alt={item.data.caption ?? item.data.title}
        class="max-h-[70vh] w-full bg-tan object-contain"
        loading="eager"
      />
      <div class="p-6 sm:p-8">
        <h1 class="text-3xl font-extrabold">{item.data.title}</h1>
        {item.data.date && <p class="mt-2 text-sm text-navy">{item.data.date.toLocaleDateString("en-UG")}</p>}
        {item.data.caption && <p class="mt-3 text-lg text-[#2C2C2C]/85">{item.data.caption}</p>}
        <div class="prose prose-stone mt-8 max-w-none prose-headings:text-coffee prose-a:text-[#C8922A]">
          <Content />
        </div>
        <p class="mt-10">
          <a class="text-sm font-semibold" href="/gallery">← Back to gallery</a>
        </p>
      </div>
    </article>
  </section>
</BaseLayout>
