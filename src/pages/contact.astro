---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { siteData } from "../data/site";
---

<BaseLayout title={`Contact | ${siteData.name}`} description="Get in touch with the minister's office.">
  <section class="container mx-auto max-w-2xl px-6 py-10 md:py-16">
    <div class="card p-6 sm:p-8 md:p-10">
      <SectionTitle
        eyebrow="Reach out"
        title="Contact"
        description="Send a message via Netlify Forms when deployed on Netlify, or use email as a fallback."
      />

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="flex flex-col gap-5"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>
            Do not fill this in: <input name="bot-field" />
          </label>
        </p>

        <div>
          <label for="name" class="mb-1 block text-sm font-semibold text-coffee">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full rounded-md border border-[#F5ECD7] bg-[#FDFAF5] px-3 py-2 text-[#2C2C2C] placeholder:text-[#2C2C2C]/40 focus:border-[#C8922A] focus:outline-none focus:ring-2 focus:ring-[#C8922A]/30"
          />
        </div>

        <div>
          <label for="email" class="mb-1 block text-sm font-semibold text-coffee">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-[#F5ECD7] bg-[#FDFAF5] px-3 py-2 text-[#2C2C2C] placeholder:text-[#2C2C2C]/40 focus:border-[#C8922A] focus:outline-none focus:ring-2 focus:ring-[#C8922A]/30"
          />
        </div>

        <div>
          <label for="message" class="mb-1 block text-sm font-semibold text-coffee">Message</label>
          <textarea
            id="message"
            name="message"
            rows={6}
            required
            class="w-full rounded-md border border-[#F5ECD7] bg-[#FDFAF5] px-3 py-2 text-[#2C2C2C] placeholder:text-[#2C2C2C]/40 focus:border-[#C8922A] focus:outline-none focus:ring-2 focus:ring-[#C8922A]/30"
          ></textarea>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <button type="submit" class="btn-solid-gold w-full sm:w-auto">Send message</button>
          <a class="btn-outline-gold w-full text-center sm:w-auto" href={`mailto:${siteData.email}`}>
            Email {siteData.email}
          </a>
        </div>
      </form>
    </div>

    <p class="mt-6 text-center text-sm text-[#2C2C2C]/75">
      On Netlify, enable form detection and check submissions in the site dashboard. For local preview, use the mailto
      link above.
    </p>
  </section>
</BaseLayout>
